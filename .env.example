# FLOW Preprocessing Service - Environment Variables
ENVIRONMENT=production
# Set to 'development' or 'production'

# API Key for authentication (REQUIRED)
API_KEY=change_this_to_your_secret_key

# Redis URL (used as Celery broker and status storage backend)
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO
LOG_TO_FILES=False

# Torch Variant (cpu or gpu with cuda)
# e.g. "cpu" (default) or "cu128" (for CUDA 12.8)
TORCH_VARIANT=cpu

# ── Celery Configuration ──────────────────────────────────────────────
# Set time limit higher in production!
CELERY_CONCURRENCY=2
CELERY_TASK_TIME_LIMIT=3600
CELERY_TASK_SOFT_TIME_LIMIT=3600

# ── HTTPS Redirect ────────────────────────────────────────────────────
# Set to 'false' when running behind a reverse proxy (e.g. Traefik) that
# handles TLS termination – otherwise redirect loops will occur.
HTTPS_REDIRECT=true

# ── Public domain (used by docker-compose.traefik.yml) ───────────────
# The hostname under which the service is reachable (without protocol).
APP_DOMAIN=preprocessing.flow-project.net

# ── CORS Configuration ────────────────────────────────────────────────
# When using Traefik, add https://<APP_DOMAIN> to CORS_ALLOWED_ORIGINS.
CORS_ALLOWED_ORIGINS='["https://preprocessing.flow-project.net"]'
CORS_ALLOWED_HEADERS='["Content-Type", "X-API-KEY"]'
CORS_ALLOWED_METHODS='["GET", "POST", "OPTIONS"]'


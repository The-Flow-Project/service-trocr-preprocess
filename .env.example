# FLOW Preprocessing Service - Environment Variables
ENVIRONMENT=production
# Set to 'development' or 'production'

# API Key for authentication (REQUIRED)
API_KEY=change_this_to_your_secret_key

# Redis URL (used as Celery broker and status storage backend)
REDIS_URL=redis://localhost:6379/0

# Logging
LOG_LEVEL=INFO
LOG_TO_FILES=False

# ── GPU Build (only used by docker-compose.gpu.yml) ───────────────────
# These build args are consumed ONLY when you stack docker-compose.gpu.yml.
# The CPU bases pass no build args, so they ignore these entirely.
# The cu124 wheel bundles its own CUDA libraries — no CUDA base image is
# needed, only the host NVIDIA driver via the NVIDIA Container Toolkit.
# torch ↔ CUDA combos: https://pytorch.org/get-started/previous-versions/
#   cu124 → CUDA 12.4   |   cu126 → CUDA 12.6   |   cu128 → CUDA 12.8
TORCH_VERSION=2.7.1
TORCHVISION_VERSION=0.22.1
TORCH_VARIANT=cu124

# ── Celery Configuration ──────────────────────────────────────────────
# Set time limit higher in production!
CELERY_CONCURRENCY=2
CELERY_TASK_TIME_LIMIT=3600
CELERY_TASK_SOFT_TIME_LIMIT=3600

# ── HTTPS Redirect ────────────────────────────────────────────────────
# Set to 'false' when running behind a reverse proxy (e.g. Traefik) that
# handles TLS termination – otherwise redirect loops will occur.
HTTPS_REDIRECT=true

# ── Public domain (used by docker-compose.traefik.yml) ───────────────
# The subdomain under which the service is reachable (without protocol).
# Requires a DNS A/AAAA record pointing this name at the host's public IP.
APP_DOMAIN=preprocessing.flow-project.net

# ── Let's Encrypt (only used by docker-compose.traefik-proxy.yml) ─────
# E-mail for ACME/Let's Encrypt expiry notifications. Required when you run
# your OWN Traefik via traefik-proxy.yml; ignored when joining an existing proxy.
ACME_EMAIL=admin@flow-project.net

# ── CORS Configuration ────────────────────────────────────────────────
# When using Traefik, add https://<APP_DOMAIN> to CORS_ALLOWED_ORIGINS.
CORS_ALLOWED_ORIGINS='["https://preprocessing.flow-project.net"]'
CORS_ALLOWED_HEADERS='["Content-Type", "X-API-KEY"]'
CORS_ALLOWED_METHODS='["GET", "POST", "OPTIONS"]'


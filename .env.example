# FLOW Preprocessing Service - Environment Variables
ENVIRONMENT=production
# Set to 'development' or 'production'

# API Key for authentication (REQUIRED)
API_KEY=change_this_to_your_secret_key

# Storage Configuration (currently only "json" is supported)
STORAGE_TYPE=json
STORAGE_PATH=./preprocessing-status.json

# Logging
LOG_LEVEL=INFO

# CORS Configuration
CORS_ALLOWED_ORIGINS='["https://app.example.com"]'
CORS_ALLOWED_HEADERS='["Content-Type", "X-API-KEY"]'
CORS_ALLOWED_METHODS='["GET", "POST", "OPTIONS"]'

